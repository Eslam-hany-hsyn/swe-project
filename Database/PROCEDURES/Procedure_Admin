CREATE OR REPLACE PROCEDURE sp_GetPendingEvents (
    p_cursor OUT SYS_REFCURSOR
)
AS
BEGIN
    OPEN p_cursor FOR
        SELECT e.EVENTID,
               e.TITLE,
               TO_CHAR(ts.SLOTDATE,  'DD/MM/YYYY') AS SLOTDATE,
               TO_CHAR(ts.STARTTIME, 'HH24:MI')    AS STARTTIME,
               e.STATUS
        FROM   Events    e
        JOIN   TimeSlots ts ON e.TIMESLOTID = ts.TIMESLOTID
        WHERE  e.STATUS = 'Pending'
        ORDER  BY ts.SLOTDATE ASC;
END sp_GetPendingEvents;
/

-- 5. Stored Procedure for Admin A.3 — single row, OUT NUMBER, no cursor
CREATE OR REPLACE PROCEDURE sp_GetEventOrganizerID (
    p_eventID     IN  NUMBER,
    p_organizerID OUT NUMBER,
    p_title       OUT VARCHAR2
)
AS
BEGIN
    SELECT ORGANIZERID, TITLE
    INTO   p_organizerID, p_title
    FROM   Events
    WHERE  EVENTID = p_eventID;

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        p_organizerID := -1;
        p_title       := '';
END sp_GetEventOrganizerID;
/

